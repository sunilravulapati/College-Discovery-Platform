generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String

  savedColleges SavedCollege[]

  createdAt DateTime @default(now())
}

model College {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  location    String
  state       String
  fees        Int
  rating      Float
  description String?

  courses     Course[]
  reviews     Review[]
  placements  Placement[]
  savedBy     SavedCollege[]

  createdAt   DateTime @default(now())
}

model Course {
  id          String   @id @default(cuid())
  name        String
  duration    String
  fees        Int

  collegeId   String
  college     College @relation(fields: [collegeId], references: [id])
}

model Placement {
  id               String   @id @default(cuid())
  avgPackage       Float
  highestPackage   Float
  placementRate    Float

  collegeId        String
  college          College @relation(fields: [collegeId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  rating      Float
  comment     String

  collegeId   String
  college     College @relation(fields: [collegeId], references: [id])

  createdAt   DateTime @default(now())
}

model SavedCollege {
  id          String   @id @default(cuid())

  userId      String
  collegeId   String

  user        User @relation(fields: [userId], references: [id])
  college     College @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}